# ── Database ──────────────────────────────────────────────────────────────────
# Use the Supabase SESSION pooler (port 5432, NOT the transaction pooler on 6543).
# Format: postgresql+asyncpg://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Synchronous URL used by Alembic migrations only (psycopg2, same host as above).
SYNC_DATABASE_URL=postgresql+psycopg2://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# JWT secret for HS256 fallback path (legacy). Found in: Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Authentication ────────────────────────────────────────────────────────────
# Algorithm used to verify JWTs. ES256 is the current Supabase default.
JWT_ALGORITHM=ES256

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Must include the production frontend URL.
# Production:  https://reliantoperations.site,https://www.reliantoperations.site
# Local dev:   http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── App settings ─────────────────────────────────────────────────────────────
# Set to "production" on Render; "development" enables /docs, verbose logging, full error detail.
FLASK_ENV=development

# Hours before an unactioned escalation is auto-escalated to BM.
AUTO_ESCALATION_TIMEOUT_HOURS=4

# Maximum upload size in MB enforced at the middleware layer (returns 413 if exceeded).
MAX_UPLOAD_SIZE_MB=10

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Optional. Transactional emails are suppressed (logged only) when this is blank.
# Obtain from: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_API_KEY

# From address must be verified in Resend (a domain DNS record).
EMAIL_FROM=noreply@reliantoperations.site
EMAIL_FROM_NAME=Reliant Anchor Operations

# ── WhatsApp / Twilio ─────────────────────────────────────────────────────────
# Optional. WhatsApp notifications are suppressed when these are blank.
# Obtain from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio WhatsApp sandbox number. Change to your approved number when leaving sandbox.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
# Optional. Error tracking is disabled when blank.
# Obtain from: https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN=
